{
  "name": "monday-integration-quickstart-app-typescript",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run server",
    "dev-server": "ts-node-dev --transpile-only --skip-ignore --watch ./.env ./src/app.ts",
    "server": "ts-node --transpile-only --skipIgnore ./src/app.ts",
    "repair:session-feedback-tokens": "ts-node --transpile-only --skipIgnore ./src/scripts/reconcile-session-feedback-token-columns.ts",
    "expose": "ngrok http 8308",
    "stop": "kill-port 8308 && kill-port 4049 && kill-port 4040",
    "build": "npx tsc"
  },
  "dependencies": {
    "@types/node": "^22.13.0",
    "amqplib": "^0.10.3",
    "axios": "^1.1.2",
    "bluebird": "^3.7.2",
    "body-parser": "1.19.0",
    "clicksend": "5.0.37",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "5.0.1",
    "express": "4.17.1",
    "googleapis": "^140.0.1",
    "helmet": "6.0.0",
    "http": "^0.0.1-security",
    "jsonwebtoken": "8.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "monday-sdk-js": "^0.5.6",
    "morgan": "^1.10.0",
    "mysql2": "^3.0.1",
    "node-cron": "^3.0.2",
    "querystring": "0.2.0",
    "redis": "^4.5.0",
    "request": "^2.88.2",
    "sequelize": "^6.28.0",
    "typeorm": "^0.3.25",
    "winston": "3.8.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/express": "4.17.9",
    "@types/jsonwebtoken": "8.5.0",
    "chai": "4.1.2",
    "concurrently": "5.2.0",
    "cross-port-killer": "1.2.1",
    "debug": "~2.6.9",
    "eslint": "v6.8.0",
    "mocha": "^10.1.0",
    "mock-require": "3.0.1",
    "ngrok": "3.2.7",
    "nodemon": "^2.0.20",
    "nyc": "^15.1.0",
    "sinon": "7.4.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "^5.9.2"
  }
